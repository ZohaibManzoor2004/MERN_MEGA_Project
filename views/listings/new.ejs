<% layout("./layouts/boilerplate.ejs") %>

<div  class="row">
    <div class ="col-8 offset-2">
        <form  class="needs-validation" method="POST" action="/listings" novalidate>
            <br>
            <br>
        <h3>Create New Listing</h3>
        <div class="mb-3">
            <label for="title" class="from-label">Title</label>
            <input name= "listing[title]" placeholder="Enter Name" 
            class="form-control" 
            required >
        </div>
        <div class="mb-3"> 
            <label for="description" class="from-label" >Description</label>
            <textarea name="listing[description]" placeholder="Enter Description" 
            class="form-control"
            required ></textarea>
        </div>
        <div class="mb-3">
            <label for="image" class="from-label"class="from-label" >Image</label>
            <input name="listing[image][url]" placeholder="Enter Image URL" class="form-control">
        </div>
        <div class="row">       
            <div class="mb-3 col-md-4">
                <label for="title" class="from-label" class="from-label">Price</label>
                <input name="listing[price]" placeholder="1200" type="number"
                 class="form-control"
                 required>
            </div>
            <div class="mb-3 col-md-8">
                <label for="country" class="from-label" class="from-label">Country</label>
                <input name="listing[country]" placeholder="Pakistan" class="form-control"
                required>
            </div>
        </div>
        <div class="mb-3"> 
            <label for="location" class="from-label" class="from-label">Location</label>
            <input name="listing[location]" placeholder="Naran/Kaghan" class="form-control">
        </div>
        <br>
        <div>
            <button class="btn btn-dark add-btn">Add Listing</button>
        </div>
        <br><br>
        </form>
    </div>
</div>
    
</body>