<% layout("./layouts/boilerplate.ejs") %>

<body>
    <h3>Edit Your Listing</h3>
    <div class="row">
        <div class="col-8 offset-2">
            <form method="POST" action="/listing/<%= listing._id %> /edit?_method=PUT">
                <div class="mb-3"> 
                    <label for="title" class="from-label">Title</label>
                    <input name= "listing[title]" placeholder="Enter Name" value="<%= listing.title %>" class="form-control" >
                </div>
                <div class="mb-3">
                    <label for="description" class="from-label" >Description</label>
                    <textarea name="listing[description]" placeholder="Enter Description" 
                    value="<%= listing.description %>" class="form-control"><%= listing.description %></textarea>
                </div>
                <div class="mb-3">
                    <label for="image" class="from-label" >Image</label>
                    <input name="listing[image][url]" value="<%= listing.image.url %>" placeholder="Enter Image URL" 
                    class="form-control">
                </div>
                <div class="row">
                    <div class="mb-3 col-md-4">
                        <label for="price" class="from-label" >Price</label>
                        <input name="listing[price]" value="<%= listing.price %>" placeholder="Enter Price" type="number" 
                        class="form-control">
                    </div>
                    <div class="mb-3 col-md-8">
                        <label for="country" class="from-label" >Country</label>
                        <input name="listing[country]" value="<%= listing.country %>" placeholder="Enter Country Name" 
                        class="form-control">
                    </div></div>
                <div class="mb-3">
                    <label for="location" class="from-label" >Location</label>
                    <input name="listing[location]" value="<%= listing.location %>" placeholder="Enter Location" 
                    class="form-control">
                </div>
                <button class="btn btn-dark add-btn">Add Listing</button>
            </form>
        </div>
    </div>
</body>
</html>